datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String     @id @default(uuid())
  name          String
  phone         String     @unique
  password_hash String
  createdAt     DateTime   @default(now()) @map("created_at")
  customers     Customer[]
  credits       Credit[]
  reviews       Review[]

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  shopId    String   @map("shop_id")
  name      String
  phone     String
  createdAt DateTime @default(now()) @map("created_at")
  shop      User     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  credits   Credit[]
  reviews   Review[]

  // Prevent duplicate customer phone per shop
  @@unique([shopId, phone])
  @@map("customers")
}

enum CreditStatus {
  ACTIVE
  OVERDUE
  CLOSED
}

model Credit {
  id         String       @id @default(uuid())
  shopId     String       @map("shop_id")
  customerId String       @map("customer_id")
  amount     Float
  dueDate    DateTime     @map("due_date")
  status     CreditStatus @default(ACTIVE)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  shop       User         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("credits")
}

model Review {
  id         String   @id @default(uuid())
  shopId     String   @map("shop_id")
  customerId String   @map("customer_id")
  rating     Int
  comment    String
  createdAt  DateTime @default(now()) @map("created_at")
  shop       User     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
